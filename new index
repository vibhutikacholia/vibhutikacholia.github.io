  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:           #005BB3;
      --text:         #ffffff;
      --muted:        #a8c8ea;
      --accent:       #d8226c;
      --accent-pale:  rgba(216, 34, 108, 0.2);
      --border:       #0048a0;
      --card:         #7eb9e0;
      --card-text:    #0c1b2e;
      --green:        #00c588;
      --font:         'Inter', system-ui, -apple-system, sans-serif;
      --mono:         'Courier New', Courier, monospace;
    }

    html { font-size: 16px; scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      font-weight: 400;
      line-height: 1.7;
      min-height: 100vh;
    }

    /* ── Layout ── */
    .wrap {
      max-width: 720px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    /* ── Header ── */
    header {
      padding: 2rem 0;
      border-bottom: 1px solid var(--border);
      margin-bottom: 4rem;
    }

    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .site-name {
      font-weight: 600;
      font-size: 0.95rem;
      letter-spacing: 0.06em;
      color: var(--text);
      cursor: pointer;
      text-transform: lowercase;
      transition: color 0.15s;
    }

    .site-name:hover { color: var(--accent); }

    nav { display: flex; flex-wrap: wrap; gap: 0; }

    nav button {
      background: none;
      border: none;
      cursor: pointer;
      font-family: var(--font);
      font-size: 0.82rem;
      font-weight: 400;
      color: var(--muted);
      padding: 0.3rem 0.8rem;
      transition: color 0.15s;
      letter-spacing: 0.01em;
    }

    nav button:last-child { padding-right: 0; }
    nav button:hover, nav button.active { color: var(--accent); }

    /* ── Page show/hide ── */
    main { padding-bottom: 7rem; }
    .page { display: none; }
    .page.active { display: block; }

    /* ══════════════════════════════════
       HOME
    ══════════════════════════════════ */

    .home-hero {
      margin-bottom: 3.5rem;
    }

    .home-hero h1 {
      font-size: 2.6rem;
      font-weight: 300;
      line-height: 1.2;
      margin-bottom: 1.25rem;
      letter-spacing: -0.03em;
      color: var(--text);
    }

    .home-hero p {
      font-size: 1.05rem;
      line-height: 1.8;
      color: var(--text);
      max-width: 560px;
    }

    /* "these days" box */
    .home-currently {
      margin-bottom: 3.5rem;
      padding: 1.75rem 2rem;
      background: var(--card);
      border-left: 3px solid #f86a38;
    }

    .currently-label {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--card-text);
      opacity: 0.6;
      margin-bottom: 1.1rem;
    }

    .currently-list {
      list-style: none;
      display: grid;
      gap: 0.65rem;
    }

    .currently-list li {
      display: flex;
      gap: 1.25rem;
      align-items: baseline;
      font-size: 0.93rem;
      color: var(--card-text);
    }

    .currently-cat {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      min-width: 78px;
      flex-shrink: 0;
    }

    /* Section links grid */
    .home-sections {
      border-top: 1px solid var(--border);
    }

    .home-section-item {
      border-bottom: 1px solid var(--border);
      padding: 1.1rem 0;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      transition: background 0.12s;
    }

    .home-section-item:hover { background: var(--accent-pale); margin: 0 -1rem; padding-left: 1rem; padding-right: 1rem; }

    .home-section-name {
      font-weight: 500;
      font-size: 0.95rem;
    }

    .home-section-arrow {
      color: var(--muted);
      font-size: 1rem;
      flex-shrink: 0;
      transition: transform 0.15s, color 0.15s;
    }

    .home-section-item:hover .home-section-arrow {
      transform: translateX(3px);
      color: var(--accent);
    }

    /* ══════════════════════════════════
       SECTION PAGES — shared
    ══════════════════════════════════ */

    .page-header {
      margin-bottom: 2.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--border);
    }

    .page-title {
      font-size: 1.8rem;
      font-weight: 300;
      letter-spacing: -0.025em;
      line-height: 1.2;
      margin-bottom: 0.4rem;
    }

    .page-subtitle {
      font-size: 0.88rem;
      color: var(--muted);
      line-height: 1.6;
      max-width: 520px;
    }

    /* ── Post list ── */
    .post-list { list-style: none; }

    .post-list-item {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1.5rem;
      padding: 1.1rem 0;
      border-bottom: 1px solid var(--border);
      cursor: pointer;
    }

    .post-list-item:first-child { border-top: 1px solid var(--border); }
    .post-list-item:hover .post-list-title { color: var(--accent); }

    .post-list-title {
      font-size: 0.97rem;
      font-weight: 400;
      transition: color 0.15s;
    }

    .post-list-date {
      font-size: 0.73rem;
      font-family: var(--mono);
      color: var(--muted);
      white-space: nowrap;
      flex-shrink: 0;
    }

    /* ── Post detail ── */
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.78rem;
      color: var(--muted);
      cursor: pointer;
      margin-bottom: 2.5rem;
      transition: color 0.15s;
      background: none;
      border: none;
      padding: 0;
      font-family: var(--font);
    }

    .back-link:hover { color: var(--accent); }

    .post-detail-date {
      font-size: 0.73rem;
      font-family: var(--mono);
      color: var(--muted);
      margin-bottom: 0.75rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .post-detail-title {
      font-size: 2rem;
      font-weight: 300;
      letter-spacing: -0.03em;
      line-height: 1.2;
      margin-bottom: 2rem;
    }

    .post-body {
      font-size: 0.97rem;
      line-height: 1.85;
      color: var(--text);
      max-width: 600px;
    }

    .post-body p + p { margin-top: 1.4rem; }
    .post-body h2 {
      font-size: 1.1rem;
      font-weight: 500;
      margin: 2.5rem 0 0.9rem;
      color: var(--text);
    }
    .post-body img {
      width: 100%;
      margin: 2rem 0;
      display: block;
    }

    /* ══════════════════════════════════
       FERMENTATION
    ══════════════════════════════════ */

    .ferm-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .ferm-card {
      background: var(--card);
      overflow: hidden;
    }

    .ferm-photo {
      aspect-ratio: 4/3;
      background: var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      color: var(--card-text);
      opacity: 0.5;
      overflow: hidden;
    }

    .ferm-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .ferm-info {
      padding: 1rem 1.25rem 1.25rem;
    }

    .ferm-status {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }

    .status-active  { color: var(--green); }
    .status-complete { color: var(--muted); }
    .status-dormant  { color: #f86a38; }

    .ferm-name {
      font-size: 0.97rem;
      font-weight: 500;
      color: var(--card-text);
      margin-bottom: 0.35rem;
    }

    .ferm-desc {
      font-size: 0.82rem;
      color: var(--card-text);
      line-height: 1.55;
      opacity: 0.75;
    }

    .ferm-date {
      font-size: 0.7rem;
      font-family: var(--mono);
      color: var(--card-text);
      opacity: 0.5;
      margin-top: 0.6rem;
    }

    /* ══════════════════════════════════
       INSTAGRAM ARCHIVE
    ══════════════════════════════════ */

    .ig-note {
      background: var(--card);
      border: 1px dashed var(--border);
      padding: 1.5rem 2rem;
      font-size: 0.83rem;
      color: var(--muted);
      line-height: 1.65;
      margin-bottom: 2rem;
    }

    .ig-note code {
      font-family: var(--mono);
      font-size: 0.78rem;
      background: var(--border);
      padding: 0.1rem 0.3rem;
    }

    .ig-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 4px;
    }

    .ig-photo {
      aspect-ratio: 1;
      background: var(--card);
      overflow: hidden;
    }

    .ig-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: opacity 0.2s;
    }

    .ig-photo img:hover { opacity: 0.9; }

    /* ── Empty state ── */
    .empty {
      font-style: italic;
      color: var(--muted);
      font-size: 0.85rem;
      padding: 3rem 0;
    }

    /* ── Footer ── */
    footer {
      border-top: 1px solid var(--border);
      padding: 2rem 0;
      font-family: var(--mono);
      font-size: 0.73rem;
      color: var(--muted);
    }

    /* ── Responsive ── */
    @media (max-width: 560px) {
      .header-inner { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
      nav button { padding: 0.3rem 0.5rem; }
      nav button:first-child { padding-left: 0; }
      .home-hero h1 { font-size: 2rem; }
      .ferm-grid { grid-template-columns: 1fr; }
      .ig-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
